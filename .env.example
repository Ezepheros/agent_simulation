# LMStudio server (must be running locally)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Gmail OAuth2 credentials file (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=~/.config/small_agent/gmail_credentials.json

# Optional: override token cache location
# GMAIL_TOKEN_PATH=~/.config/small_agent/gmail_token.json
