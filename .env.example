# LMStudio server (must be running locally)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Gmail OAuth2 credentials file (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=~/.config/small_agent/gmail_credentials.json

# Optional: override token cache locations
# GMAIL_TOKEN_PATH=~/.config/small_agent/gmail_token.json
# CALENDAR_TOKEN_PATH=~/.config/small_agent/calendar_token.json
# SHEETS_TOKEN_PATH=~/.config/small_agent/sheets_token.json
# DOCS_TOKEN_PATH=~/.config/small_agent/docs_token.json

# Tavily search API key (https://app.tavily.com)
TAVILY_API_KEY=your-tavily-api-key-here
